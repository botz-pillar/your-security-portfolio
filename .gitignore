crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Environment variables and secrets
.env
.env.*

# Private keys
*.pem
*.key

# Dependencies
node_modules/

# Optional: ignore local editor/system clutter
.vscode/

